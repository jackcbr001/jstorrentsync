generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(cuid())
  name        String
  description String?
  sourcePath  String
  destPath    String
  status      JobStatus @default(IDLE)
  schedule    String?   // cron expression
  lastSync    DateTime?
  nextSync    DateTime?
  autoSync    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  torrents    Torrent[]
  logs        SyncLog[]

  @@map("jobs")
}

model Torrent {
  id          String   @id @default(cuid())
  jobId       String
  name        String
  infoHash    String   @unique
  magnetLink  String   @db.Text
  size        BigInt
  progress    Float    @default(0)
  status      TorrentStatus @default(PENDING)
  downloadSpeed Float  @default(0)
  uploadSpeed  Float  @default(0)
  peers       Int      @default(0)
  seeds       Int      @default(0)
  filePath    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  files       TorrentFile[]

  @@map("torrents")
}

model TorrentFile {
  id        String @id @default(cuid())
  torrentId String
  name      String
  path      String
  size      BigInt
  progress  Float  @default(0)

  torrent   Torrent @relation(fields: [torrentId], references: [id], onDelete: Cascade)

  @@map("torrent_files")
}

model SyncLog {
  id        String   @id @default(cuid())
  jobId     String
  level     LogLevel @default(INFO)
  message   String   @db.Text
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("settings")
}

enum JobStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
  COMPLETED
}

enum TorrentStatus {
  PENDING
  DOWNLOADING
  SEEDING
  PAUSED
  ERROR
  COMPLETED
}

enum LogLevel {
  INFO
  WARN
  ERROR
  SUCCESS
}
